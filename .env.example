# Database
DATABASE_URL="postgresql://user:password@localhost:5432/exclsv_crm?schema=public"

# Auth.js
AUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Redis
REDIS_URL="redis://localhost:6379"

# Socket.io
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# Resend (email)
RESEND_API_KEY="re_your_resend_api_key"

# Cron jobs
CRON_SECRET="generate-a-secret-with-openssl-rand-base64-32"

# Push notifications (VAPID) — generate with: node scripts/generate-vapid-keys.js
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"

# File uploads (S3 or local)
UPLOAD_DIR="./uploads"
